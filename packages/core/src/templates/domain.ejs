<%
  function getTsType(field) {
    if (field.ref) {
      const baseType = pascalCase(field.ref);
      return field.isArray ? `${baseType}[]` : baseType;
    }
    if (field.isDate) return 'Date';
    if (field.type === 'integer' || field.type === 'number') return 'number';
    if (field.type === 'boolean') return 'boolean';
    if (field.type === 'array') return 'any[]';
    if (field.type === 'object') return 'Record<string, unknown>';
    return 'string';
  }
  
  const imports = new Set();
  entity.fields.forEach(f => {
    if (f.ref && f.ref !== entity.name) {
      imports.add(`import { ${pascalCase(f.ref)}${config.naming.domainSuffix ? config.naming.domainSuffix : ''} } from "./${kebabCase(f.ref)}";`);
    }
  });
-%>
<% Array.from(imports).forEach(imp => { -%>
<%- imp %>
<% }); -%>

<% if (entity.fields.length === 0) { -%>
export type <%= pascalCase(entity.name) %><%- config.naming.domainSuffix ? config.naming.domainSuffix : '' %> = Record<string, unknown>;
<% } else { -%>
export interface <%= pascalCase(entity.name) %><%- config.naming.domainSuffix ? config.naming.domainSuffix : '' %> {
<% entity.fields.forEach(field => { -%>
  <%= camelCase(field.name) %><%- field.required ? '' : '?' %>: <%- getTsType(field) %>;
<% }); -%>
}
<% } -%>
