import { Injectable } from '@angular/core';
import { <%= entity.name %>Service } from '../../core/services/<%= kebabCase(entity.name) %>.service';
import { Result } from '../../core/types/result';
<% 
  const domains = new Set();
  const dtosForInput = new Set();
  entity.endpoints.forEach(ep => {
    if (ep.requestFields && ep.requestFields.length > 0 && ep.requestFields[0]?.ref) dtosForInput.add(`${ep.requestFields[0].ref}DTO`);
    if (ep.responseFields && ep.responseFields.length > 0 && ep.responseFields[0]?.ref) {
      domains.add(ep.responseFields[0].ref);
    }
  });

  Array.from(domains).forEach(domain => {
-%>
import { <%= domain %> } from '../../core/domain/<%= kebabCase(domain) %>';
<% }); -%>
<% Array.from(dtosForInput).forEach(dto => { -%>
import { <%= dto %> } from "../../core/dto/<%= snakeCase(dto.replace('DTO','')) %>.dto";
<% }); -%>

@Injectable({
  providedIn: 'root'
})
export class <%= entity.name %>AngularService {
<% entity.endpoints.forEach(ep => { 
     const req = ep.requestFields ? ep.requestFields[0] : null;
     const res = ep.responseFields ? ep.responseFields[0] : null;
     
     const reqType = req ? (req.ref ? `${req.ref}DTO${req.isArray ? '[]' : ''}` : 'any') : 'any';
     const domainName = res ? (res.ref ? res.ref : 'any') : 'void';
     const resType = domainName !== 'void' ? `${domainName}${res.isArray ? '[]' : ''}` : 'void';
     
     const isGet = ep.method === 'GET' || ep.method === 'DELETE';
     const params = isGet ? '' : (reqType !== 'any' ? `data: ${reqType}` : 'data?: any');
     const executeArgs = isGet ? '' : (reqType !== 'any' ? `data` : '');
-%>
  async <%= camelCase(ep.name) %>(<%- params %>): Promise<Result<<%- resType %>>> {
    return <%= entity.name %>Service.<%= camelCase(ep.name) %>(<%- executeArgs %>);
  }
<% }); -%>
}
