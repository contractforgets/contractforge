import { ref } from 'vue';
import { <%= pascalCase(entity.name) %><%= config.naming.serviceSuffix %> } from '../../core/services/<%= kebabCase(entity.name) %>.service';
import { DomainError, Result } from '../../core/types/result';
<% 
  const domains = new Set();
  const dtosForInput = new Set();
  entity.endpoints.forEach(ep => {
    if (ep.requestFields && ep.requestFields.length > 0 && ep.requestFields[0]?.ref) dtosForInput.add(pascalCase(ep.requestFields[0].ref));
    if (ep.responseFields && ep.responseFields.length > 0 && ep.responseFields[0]?.ref) {
      domains.add(pascalCase(ep.responseFields[0].ref));
    }
  });

  Array.from(domains).forEach(domain => {
-%>
import { <%= domain %><%- config.naming.domainSuffix ? config.naming.domainSuffix : '' %> as <%= domain %>Domain } from '../../core/domain/<%= kebabCase(domain) %>';
<% }); -%>
<% Array.from(dtosForInput).forEach(dto => { -%>
import { <%= dto %><%= config.naming.dtoSuffix %> as <%= dto %>Dto } from "../../core/dto/<%= snakeCase(dto) %><%= config.naming?.dtoSuffix ? '.' + config.naming.dtoSuffix.toLowerCase() : '' %>";
<% }); -%>

<% entity.endpoints.forEach(ep => { 
     const req = ep.requestFields ? ep.requestFields[0] : null;
     const res = ep.responseFields ? ep.responseFields[0] : null;
     
     const reqType = req ? (req.ref ? `${pascalCase(req.ref)}Dto${req.isArray ? '[]' : ''}` : 'any') : 'any';
     const domainName = res ? (res.ref ? pascalCase(res.ref) : 'any') : 'void';
     const resType = domainName !== 'void' ? `${domainName}Domain${res.isArray ? '[]' : ''}` : 'void';
     
     const isGet = ep.method === 'GET' || ep.method === 'DELETE';
     const params = isGet ? '' : (reqType !== 'any' ? `data: ${reqType}` : 'data?: any');
     const executeArgs = isGet ? '' : (reqType !== 'any' ? `data` : '');
-%>
export function use<%= pascalCase(ep.name) %>() {
  const data = ref<<%- resType %> | undefined>();
  const error = ref<DomainError | undefined>();
  const isLoading = ref(false);

  const execute = async (<%- params %>): Promise<Result<<%- resType %>>> => {
    isLoading.value = true;
    error.value = undefined;
    const result = await <%= pascalCase(entity.name) %><%= config.naming.serviceSuffix %>.<%= camelCase(ep.name) %>(<%- executeArgs %>);
    if (result.success) {
      data.value = result.data as any;
    } else {
      error.value = result.error;
    }
    isLoading.value = false;
    return result;
  };

  return { data, error, isLoading, execute };
}
<% }); -%>
